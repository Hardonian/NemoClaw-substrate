{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nemoclaw.ai/schemas/trust-decision.schema.json",
  "title": "Trust Decision",
  "description": "An authorization decision made by the policy engine based on available evidence and trust levels.",
  "type": "object",
  "properties": {
    "decisionId": {
      "type": "string"
    },
    "runId": {
      "type": "string"
    },
    "stepId": {
      "type": "string"
    },
    "planId": {
      "type": "string"
    },
    "allowed": {
      "type": "boolean"
    },
    "reasonCode": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "decidedBy": {
      "type": "string"
    },
    "policyVersion": {
      "type": "string"
    },
    "trustLevel": {
      "type": "string"
    },
    "approvalRequired": {
      "type": "boolean"
    },
    "approvalGranted": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["decisionId", "runId", "planId", "allowed", "reasonCode", "message", "decidedAt", "approvalRequired"]
}
