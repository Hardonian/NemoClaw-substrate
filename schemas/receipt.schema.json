{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionReceipt",
  "description": "Immutable record of discrete events.",
  "type": "object",
  "properties": {
    "receiptId": { "type": "string" },
    "type": { "type": "string", "const": "ExecutionReceipt" },
    "timestamp": { "type": "string", "format": "date-time" },
    "redacted": { "type": "boolean" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stepId": { "type": "string" },
          "status": { "type": "string" }
        },
        "required": ["stepId", "status"]
      }
    }
  },
  "required": ["receiptId", "type", "timestamp", "steps"]
}
