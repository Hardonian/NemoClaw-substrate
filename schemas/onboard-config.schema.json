{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nemoclaw.ai/schemas/onboard-config.schema.json",
  "title": "NemoClaw Onboard Configuration",
  "description": "Schema for the NemoClaw onboarding configuration stored at ~/.nemoclaw/config.json. Contains sandbox, provider, and inference settings.",
  "type": "object",
  "properties": {
    "sandbox": {
      "type": "object",
      "description": "Sandbox configuration set during onboarding.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the sandbox."
        },
        "image": {
          "type": "string",
          "description": "Container image used for the sandbox."
        },
        "profile": {
          "type": "string",
          "description": "Inference profile name."
        }
      }
    },
    "provider": {
      "type": "object",
      "description": "Inference provider configuration.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Provider type (e.g., ollama, nim, vllm)."
        },
        "model": {
          "type": "string",
          "description": "Model identifier."
        },
        "endpoint": {
          "type": "string",
          "description": "Provider API endpoint URL."
        }
      }
    },
    "agent": {
      "type": "string",
      "description": "Agent type (e.g., openclaw, hermes)."
    },
    "onboardedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when onboarding was completed."
    },
    "version": {
      "type": "string",
      "description": "Configuration schema version."
    }
  },
  "additionalProperties": true
}
