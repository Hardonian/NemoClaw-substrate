{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReplayEnvelope",
  "description": "Container for replay validation results.",
  "type": "object",
  "properties": {
    "envelopeId": { "type": "string" },
    "type": { "type": "string", "const": "ReplayEnvelope" },
    "timestamp": { "type": "string", "format": "date-time" },
    "redacted": { "type": "boolean" },
    "receiptId": { "type": "string" },
    "verified": { "type": "boolean" }
  },
  "required": ["envelopeId", "type", "timestamp", "receiptId", "verified"]
}
