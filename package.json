{
  "name": "nemoclaw",
  "version": "0.1.0",
  "description": "NemoClaw — run OpenClaw inside OpenShell with NVIDIA inference",
  "license": "Apache-2.0",
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js",
    "nemohermes": "./bin/nemohermes.js"
  },
  "oclif": {
    "bin": "nemoclaw",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "flexibleTaxonomy": true,
    "topicSeparator": " "
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "test": "vitest run",
    "check": "npx prek run --all-files",
    "checks": "tsx scripts/checks/run.ts",
    "lint": "npx @biomejs/biome lint . && npm run checks",
    "lint:fix": "npx @biomejs/biome lint --write . && npm run checks",
    "lint:ts": "cd nemoclaw && npm run check",
    "format": "npx @biomejs/biome format --write .",
    "format:check": "npx @biomejs/biome format --check .",
    "format:ts": "cd nemoclaw && npm run lint:fix && npm run format",
    "check:installer-hash": "bash scripts/check-installer-hash.sh",
    "typecheck": "tsc -p jsconfig.json",
    "build:cli": "tsc -p tsconfig.src.json && tsc -p nemoclaw-blueprint/tsconfig.json",
    "typecheck:cli": "tsc -p tsconfig.cli.json",
    "validate:configs": "tsx scripts/validate-configs.ts",
    "migrate:js-to-ts": "tsx scripts/migrate-js-to-ts.ts",
    "ts-migration:assist": "tsx scripts/ts-migration-assist.ts",
    "ts-migration:bulk-fix-prs": "tsx scripts/ts-migration-bulk-fix-prs.ts",
    "ts-migration:guard": "tsx scripts/check-legacy-migrated-paths.ts",
    "type-safety:hotspots": "tsx scripts/type-safety-hotspots.ts",
    "source-shape:scan": "tsx scripts/find-source-shape-tests.ts --metrics",
    "source-shape:check": "tsx scripts/find-source-shape-tests.ts --check",
    "bump:version": "tsx scripts/bump-version.ts",
    "docs": "uv run --group docs sphinx-build -b html docs docs/_build/html",
    "docs:strict": "uv run --group docs sphinx-build -W -b html docs docs/_build/html",
    "docs:live": "uv run --group docs sphinx-autobuild docs docs/_build/html --open-browser",
    "docs:clean": "rm -rf docs/_build",
    "prepare": "if [ -x node_modules/.bin/tsc ]; then npm run build:cli; else echo \"Skipping CLI build during prepare (local TypeScript not installed yet)\"; fi && if [ -d .git ]; then bash scripts/npm-link-or-shim.sh; if command -v prek >/dev/null 2>&1; then prek install; else echo \"Skipping git hook setup (prek not installed)\"; fi; fi",
    "prepublishOnly": "git describe --tags --match 'v*' | sed 's/^v//' > .version && test -s .version && cd nemoclaw && env -u npm_config_global -u npm_config_prefix -u npm_config_omit npm install --ignore-scripts && ./node_modules/.bin/tsc",
    "verify:changelog-hygiene": "node scripts/verify-changelog-hygiene.js",
    "verify:control-plane": "vitest run src/lib/control-plane/control-plane.test.ts src/lib/control-plane/runtime-seams.test.ts src/lib/control-plane/runtime-dispatch-integration.test.ts src/lib/control-plane/execution-plans.test.ts src/lib/control-plane/execution-lifecycle.test.ts src/lib/control-plane/evidence-export.test.ts",
    "verify:execution-lifecycle": "vitest run src/lib/control-plane/execution-lifecycle.test.ts",
    "verify:local-probes": "vitest run src/lib/control-plane/local-runtime-probes.test.ts src/lib/control-plane/local-diagnostics-summary.test.ts",
    "verify:remote-probes": "vitest run src/lib/control-plane/remote-runtime-probes.test.ts src/lib/control-plane/worker-probes.test.ts",
    "verify:governed-routing": "vitest run src/lib/control-plane/governed-provider-routing.test.ts",
    "verify:core": "node scripts/verify-core.js",
    "verify:all": "npm run verify:core -- --strict",
    "verify:chaos": "vitest run src/lib/control-plane/degraded-state-chaos.test.ts src/lib/control-plane/execution-lifecycle.test.ts",
    "verify:release": "npm run verify:changelog-hygiene && npm run verify:core && npm run typecheck && npm run lint && npm run verify:chaos",
    "verify:benchmarks": "tsx scripts/verify-benchmarks.ts",
    "verify:proofpack": "tsx scripts/verify-proofpack.ts",
    "verify:replay": "tsx scripts/verify-replay.ts",
    "verify:export": "tsx scripts/verify-export.ts",
    "verify:docs-strict": "tsx scripts/verify-docs-strict.ts",
    "review:claims": "node scripts/review/check-claims.mjs",
    "review:links": "node scripts/review/check-doc-links.mjs",
    "review:status": "node scripts/review/check-status-matrix.mjs",
    "review:theatre": "node scripts/review/check-no-theatre.mjs",
    "review:fixtures": "node scripts/review/check-fixtures-redacted.mjs",
    "review:spdx": "node scripts/review/check-spdx-docs.mjs",
    "review:proofpack": "node scripts/review/check-proofpack.mjs",
    "review:index": "node scripts/review/check-doc-index.mjs",
    "review:all": "npm run review:claims && npm run review:links && npm run review:status && npm run review:theatre && npm run review:fixtures && npm run review:spdx && npm run review:proofpack && npm run review:index",
    "review:paths": "node scripts/review/list-review-paths.mjs",
    "generate-fixtures": "tsx scripts/generate-fixtures.ts --seed 42",
    "check-fixtures": "tsx scripts/check-fixtures.ts",
    "demo:local-proof": "node scripts/demo/run-local-governed-proof.mjs",
    "demo:local-proof:verify": "node scripts/demo/verify-local-governed-proof.mjs",
    "demo:local-proof:clean": "node -e \"require('node:fs').rmSync('.artifacts/local-governed-proof',{recursive:true,force:true});console.log('cleaned .artifacts/local-governed-proof')\""
  },
  "dependencies": {
    "@oclif/core": "^4.10.5",
    "js-yaml": "^4.1.1",
    "p-retry": "^4.6.2",
    "yaml": "^2.8.3"
  },
  "bundleDependencies": [
    "p-retry"
  ],
  "files": [
    ".version",
    "bin/",
    "dist/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "engines": {
    "node": ">=22.16.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVIDIA/NemoClaw.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@j178/prek": "^0.3.6",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "execa": "^9.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
